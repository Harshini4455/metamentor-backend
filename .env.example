# ── MetaMentor Backend — Environment Variables ──────────────────────────────
# Copy this to .env and fill in your values

APP_NAME=MetaMentor AI Workspace
DEBUG=true

# PostgreSQL (local)
DATABASE_URL=postgresql+asyncpg://metamentor:metamentor@localhost:5432/metamentor

# Redis (local)
REDIS_URL=redis://localhost:6379

# AI Keys — get from https://aistudio.google.com/

# ChromaDB (local, started separately)
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=metamentor_kb

# Security
SECRET_KEY=change-me-run-openssl-rand-hex-32

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

